# Fireworks AI API Credentials
FIREWORKS_API_KEY=Key

# Fireworks AI Base Endpoint URL
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Comma-separated list of allowed models available at runtime.
# The pipeline dynamically selects from this list based on task difficulty.
ALLOWED_MODELS=accounts/fireworks/models/llama-v3p1-8b-instruct,accounts/fireworks/models/llama-v3p1-70b-instruct
